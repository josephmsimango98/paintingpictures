@page "/works"
@rendermode InteractiveServer
@inject PortfolioService PortfolioService
@inject CollectionService CollectionService

<PageTitle>@(pageTitle) — The Irony</PageTitle>

<SiteHeader />

<section class="pp-works">
    <div class="pp-studio-page-actions">
        <StudioEditLink Href="@NewItemHref" Label="@NewItemLabel" AddIcon="true" />
        <StudioEditLink Href="@CollectionsEditHref" Label="Edit collections" />
    </div>
    <div class="pp-works__intro">
        <h1 class="pp-works__title">@PortfolioMedia.PluralLabel(medium)</h1>
        <p class="pp-works__subtitle">Browse collections and works in this medium.</p>
        <div class="pp-works__filters" role="tablist" aria-label="Categories">
            <a href="/works?type=photograph&collection=all"
               class="pp-works__filter @(medium == PortfolioMedia.Photograph ? "is-active" : null)"
               role="tab"
               aria-selected="@(medium == PortfolioMedia.Photograph)">Photographs</a>
            <a href="/works?type=drawing&collection=all"
               class="pp-works__filter @(medium == PortfolioMedia.Drawing ? "is-active" : null)"
               role="tab"
               aria-selected="@(medium == PortfolioMedia.Drawing)">Drawings</a>
            <a href="/works?type=poem&collection=all"
               class="pp-works__filter @(medium == PortfolioMedia.Poem ? "is-active" : null)"
               role="tab"
               aria-selected="@(medium == PortfolioMedia.Poem)">Poems</a>
        </div>
    </div>

    <div class="pp-collection-rail-wrap">
        <div class="pp-collection-rail" role="tablist" aria-label="Collections">
            <a href="/works?type=@medium&collection=all"
               class="pp-collection-chip @(selectedSlug == "all" ? "is-active" : "")"
               role="tab"
               aria-selected="@(selectedSlug == "all")">
                <span class="pp-collection-chip__thumb">
                    @ChipCover(mediumItems.FirstOrDefault(), "All")
                </span>
                <span class="pp-collection-chip__meta">
                    <strong>All</strong>
                    <small>@mediumItems.Count</small>
                </span>
            </a>

            @foreach (var collection in customCollections)
            {
                <a href="/works?type=@medium&collection=@collection.Slug"
                   class="pp-collection-chip @(selectedSlug == collection.Slug ? "is-active" : "")"
                   role="tab"
                   aria-selected="@(selectedSlug == collection.Slug)">
                    <span class="pp-collection-chip__thumb">
                        @ChipCover(collection.CoverItem, collection.Title)
                    </span>
                    <span class="pp-collection-chip__meta">
                        <strong>@collection.Title</strong>
                        <small>@collection.ItemCount</small>
                    </span>
                </a>
            }
        </div>
    </div>

    <div class="pp-collection-stream-head">
        <div>
            <p class="pp-collection-index__eyebrow">@PortfolioMedia.PluralLabel(medium)</p>
            <h2>@selectedCollectionTitle</h2>
            @if (!string.IsNullOrWhiteSpace(selectedCollectionDescription))
            {
                <p>@selectedCollectionDescription</p>
            }
        </div>
        <span class="pp-collection-stream-head__count">
            @streamItems.Count work@(streamItems.Count == 1 ? "" : "s")
        </span>
    </div>

    @if (streamItems.Count == 0)
    {
        <div class="pp-collection-empty">
            <h3>No works in this collection yet</h3>
            <p>Choose another collection, or add works from the studio.</p>
        </div>
    }
    else
    {
        <div class="pp-photostream">
            <div class="pp-flickr-grid">
                @foreach (var row in rows)
                {
                    <div class="pp-flickr-row @(row.IsLastRow ? "pp-flickr-row--last" : "")"
                         style="--aspect-sum: @row.AspectSum.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture); --item-count: @row.Items.Count;">
                        @foreach (var item in row.Items)
                        {
                            var aspect = JustifiedGridLayout.GetAspectRatio(item);
                            <a href="/item/@item.Id"
                               class="pp-flickr-card"
                               style="--aspect: @aspect.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture);"
                               title="@item.Title">
                                @if (item.HasImage)
                                {
                                    <img src="@item.Image" alt="@item.Title" class="pp-flickr-card-img" />
                                }
                                else
                                {
                                    <div class="pp-flickr-card-poem">
                                        <span class="pp-flickr-card-poem-text">@(item.Poem?.Split('\n')[0])</span>
                                    </div>
                                }
                                <div class="pp-flickr-card-hover">
                                    <span class="pp-flickr-card-title">@item.Title</span>
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    }
</section>

<SiteFooter />

@code {
    [SupplyParameterFromQuery(Name = "type")]
    public string? Type { get; set; }

    [SupplyParameterFromQuery(Name = "collection")]
    public string? Collection { get; set; }

    private string medium = PortfolioMedia.Photograph;
    private string selectedSlug = "all";
    private IReadOnlyList<PortfolioItem> mediumItems = [];
    private IReadOnlyList<PortfolioItem> streamItems = [];
    private IReadOnlyList<PortfolioCollection> customCollections = [];
    private IReadOnlyList<JustifiedRow> rows = [];
    private string pageTitle = "Works";
    private string selectedCollectionTitle = "All";
    private string? selectedCollectionDescription;
    private string WorksReturnUrl =>
        $"/works?type={Uri.EscapeDataString(medium)}&collection={Uri.EscapeDataString(selectedSlug)}";
    private string CollectionsEditHref =>
        $"/admin/collections?medium={Uri.EscapeDataString(medium)}&returnUrl={Uri.EscapeDataString(WorksReturnUrl)}";
    private string NewItemHref =>
        $"/admin/portfolio?create=true&type={Uri.EscapeDataString(medium)}&returnUrl={Uri.EscapeDataString(WorksReturnUrl)}";
    private string NewItemLabel => medium switch
    {
        PortfolioMedia.Drawing => "Add drawing",
        PortfolioMedia.Poem => "Add poem",
        _ => "Upload photograph"
    };

    protected override async Task OnParametersSetAsync()
    {
        medium = PortfolioMedia.Normalize(Type);
        selectedSlug = string.IsNullOrWhiteSpace(Collection)
            ? "all"
            : Collection.Trim().ToLowerInvariant();

        await PortfolioService.LoadAsync();
        mediumItems = PortfolioService.GetByType(medium, publishedOnly: true);
        customCollections = await CollectionService.GetByMediumAsync(medium);

        if (selectedSlug == "all")
        {
            streamItems = mediumItems;
            selectedCollectionTitle = "All";
            selectedCollectionDescription = null;
        }
        else
        {
            var selected = await CollectionService.GetBySlugAsync(medium, selectedSlug);
            if (selected is null)
            {
                selectedSlug = "all";
                streamItems = mediumItems;
                selectedCollectionTitle = "All";
                selectedCollectionDescription = null;
            }
            else
            {
                streamItems = await CollectionService.GetItemsAsync(selected);
                selectedCollectionTitle = selected.Title;
                selectedCollectionDescription = selected.Description;
            }
        }

        rows = JustifiedGridLayout.BuildRows(streamItems);
        pageTitle = $"{PortfolioMedia.PluralLabel(medium)} · {selectedCollectionTitle}";
    }

    private static RenderFragment ChipCover(PortfolioItem? item, string label) => builder =>
    {
        if (item?.HasImage == true)
        {
            builder.OpenElement(0, "img");
            builder.AddAttribute(1, "src", item.Image);
            builder.AddAttribute(2, "alt", "");
            builder.CloseElement();
            return;
        }

        builder.OpenElement(3, "span");
        builder.AddAttribute(4, "class", "pp-collection-chip__placeholder");
        builder.AddContent(5, label.Length == 0 ? "·" : label[0].ToString().ToUpperInvariant());
        builder.CloseElement();
    };
}
