@page "/login"
@attribute [AllowAnonymous]
@rendermode InteractiveServer

<PageTitle>Sign in — The Irony</PageTitle>

<SiteHeader />

<main class="pp-login-page">
    <form method="post" action="/api/auth/login" class="pp-login-form">
        <AntiforgeryToken />
        <span class="pp-login-eyebrow">Member access</span>
        <h1 class="pp-login-title">Welcome back</h1>
        <p class="pp-login-copy">Sign in to like works, join conversations, or manage the collection.</p>
        @if (Error == "invalid")
        {
            <p class="pp-login-error">Invalid email or password.</p>
        }
        else if (Error == "notconfigured")
        {
            <p class="pp-login-error">Authentication service is not configured.</p>
        }
        @if (Registered == "true")
        {
            <p class="pp-login-success">Account created. Check your email if confirmation is enabled, then sign in.</p>
        }
        <label class="pp-login-label" for="login-email">Email</label>
        <input id="login-email" type="email" name="email" placeholder="you@example.com" class="pp-login-input" required autocomplete="email" />
        <label class="pp-login-label" for="login-password">Password</label>
        <input id="login-password" type="password" name="password" placeholder="Your password" class="pp-login-input" required autocomplete="current-password" />
        <button type="submit" class="pp-login-btn">Sign in</button>
        <p class="pp-login-switch">New to the collection? <a href="/register">Create a viewer account</a></p>
    </form>
</main>

@code {
    [SupplyParameterFromQuery] private string? Error { get; set; }
    [SupplyParameterFromQuery] private string? Registered { get; set; }
}
