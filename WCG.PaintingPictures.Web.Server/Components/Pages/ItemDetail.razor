@page "/item/{Id:int}"
@rendermode InteractiveServer
@inject PortfolioService PortfolioService
@inject SupabaseDataService Supabase
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS

<PageTitle>@(item?.Title ?? "Not Found") — The Irony</PageTitle>

@if (item != null)
{
    @if (item.HasImage)
    {
        <div class="pp-photo-view" id="pp-photo-view">
            <!-- Media viewer (left) -->
            <div class="pp-photo-viewer">
                <div class="pp-photo-viewer-top">
                    <a href="/" class="pp-photo-back">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M10.5 3.5L5.5 8l5 4.5-.7.7L4.1 8l5.7-5.2.7.7z"/></svg>
                        Back to gallery
                    </a>
                    <button class="pp-photo-fullscreen-btn" @onclick="ToggleFullscreen" title="Fullscreen">
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor"><path d="M2 7V2h5V0H0v7h2zm11-5h5v5h2V0h-7v2zm5 11h-5v2h7v-7h-2v5zM7 16H2v-5H0v7h7v-2z"/></svg>
                    </button>
                </div>

                <div class="pp-photo-stage">
                    @if (previous != null)
                    {
                        <a href="/item/@previous.Id" class="pp-photo-nav pp-photo-nav--prev" title="@previous.Title">
                            <svg width="28" height="28" viewBox="0 0 28 28" fill="currentColor"><path d="M18 6L10 14l8 8 1.4-1.4L12.8 14l6.6-6.6L18 6z"/></svg>
                        </a>
                    }

                    <img src="@item.Image" alt="@item.Title" class="pp-photo-main-img" />

                    @if (next != null)
                    {
                        <a href="/item/@next.Id" class="pp-photo-nav pp-photo-nav--next" title="@next.Title">
                            <svg width="28" height="28" viewBox="0 0 28 28" fill="currentColor"><path d="M10 6l8 8-8 8-1.4-1.4L15.2 14 8.6 7.4 10 6z"/></svg>
                        </a>
                    }
                </div>

                <div class="pp-photo-filmstrip">
                    @foreach (var thumb in allItems.Where(i => i.HasImage))
                    {
                        <a href="/item/@thumb.Id"
                           class="pp-photo-thumb @(thumb.Id == item.Id ? "pp-photo-thumb--active" : "")"
                           title="@thumb.Title">
                            <img src="@thumb.Image" alt="@thumb.Title" />
                        </a>
                    }
                </div>
            </div>

            <!-- Info sidebar (right) -->
            <aside class="pp-photo-sidebar">
                <div class="pp-photo-profile">
                    <img src="images/mimic-logo.png" alt="The Irony" class="pp-photo-avatar" />
                    <div class="pp-photo-profile-info">
                        <span class="pp-photo-author">The Irony</span>
                        <span class="pp-photo-author-handle">by joseph.</span>
                    </div>
                </div>

                <h1 class="pp-photo-title">@item.Title</h1>

                <div class="pp-photo-stats">
                    <span class="pp-type-badge">@item.TypeLabel</span>
                </div>

                @if (!string.IsNullOrEmpty(item.Description))
                {
                    <p class="pp-photo-description">@item.Description</p>
                }

                @if (!string.IsNullOrEmpty(item.Poem))
                {
                    <div class="pp-photo-poem-block">
                        <h3 class="pp-photo-section-label">The Poem</h3>
                        <p class="pp-photo-poem">@item.Poem</p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(item.Thoughts))
                {
                    <div class="pp-photo-thoughts-block">
                        <h3 class="pp-photo-section-label">Thoughts</h3>
                        <p class="pp-photo-thoughts">@item.Thoughts</p>
                    </div>
                }

                <section class="pp-engagement" aria-label="Likes and comments">
                    <div class="pp-engagement__summary">
                        <AuthorizeView>
                            <Authorized>
                                <button type="button"
                                        class="pp-like-btn @(engagement.IsLiked ? "is-liked" : "")"
                                        @onclick="ToggleLike">
                                    <span aria-hidden="true">@(engagement.IsLiked ? "♥" : "♡")</span>
                                    @(engagement.IsLiked ? "Liked" : "Like")
                                </button>
                            </Authorized>
                            <NotAuthorized>
                                <a href="/login" class="pp-like-btn">♡ Sign in to like</a>
                            </NotAuthorized>
                        </AuthorizeView>
                        <span class="pp-like-count">@engagement.LikeCount @(engagement.LikeCount == 1 ? "like" : "likes")</span>
                    </div>

                    <h2 class="pp-comments-title">Comments</h2>
                    <AuthorizeView>
                        <Authorized>
                            <div class="pp-comment-form">
                                <textarea class="pp-comment-input"
                                          @bind="newComment"
                                          maxlength="1000"
                                          placeholder="Add a thoughtful comment..."
                                          aria-label="Comment"></textarea>
                                <button type="button"
                                        class="pp-comment-submit"
                                        disabled="@string.IsNullOrWhiteSpace(newComment)"
                                        @onclick="AddComment">
                                    Post comment
                                </button>
                            </div>
                        </Authorized>
                        <NotAuthorized>
                            <p class="pp-comment-signin"><a href="/login">Sign in</a> to join the conversation.</p>
                        </NotAuthorized>
                    </AuthorizeView>

                    <div class="pp-comments-list">
                        @if (engagement.Comments.Count == 0)
                        {
                            <p class="pp-comments-empty">No comments yet.</p>
                        }
                        @foreach (var comment in engagement.Comments)
                        {
                            <article class="pp-comment">
                                <div class="pp-comment__meta">
                                    <strong>@comment.AuthorName</strong>
                                    <time datetime="@comment.CreatedAt.ToString("O")">@comment.CreatedAt.ToLocalTime().ToString("d MMM yyyy")</time>
                                </div>
                                <p>@comment.Body</p>
                            </article>
                        }
                    </div>
                </section>
            </aside>
        </div>
    }
    else
    {
        <!-- Poem / text-only fallback -->
        <div class="pp-poem-view">
            <a href="/" class="pp-photo-back pp-photo-back--poem">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M10.5 3.5L5.5 8l5 4.5-.7.7L4.1 8l5.7-5.2.7.7z"/></svg>
                Back to gallery
            </a>
            <div class="pp-poem-view-content">
                <h1 class="pp-poem-view-title">@item.Title</h1>
                <FluentBadge class="pp-type-badge pp-badge-top" Appearance="Appearance.Neutral">@item.TypeLabel</FluentBadge>

                @if (!string.IsNullOrEmpty(item.Poem))
                {
                    <p class="pp-poem-view-text">@item.Poem</p>
                }

                @if (!string.IsNullOrEmpty(item.Description))
                {
                    <p class="pp-poem-view-note">@item.Description</p>
                }

                @if (!string.IsNullOrEmpty(item.Thoughts))
                {
                    <p class="pp-poem-view-thoughts">@item.Thoughts</p>
                }
            </div>
        </div>
    }
}
else
{
    <div class="pp-detail-notfound">
        <p>Item not found.</p>
        <a href="/">Back to gallery</a>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private PortfolioItem? item;
    private PortfolioItem? previous;
    private PortfolioItem? next;
    private IReadOnlyList<PortfolioItem> allItems = default!;
    private EngagementSummary engagement = new(0, false, []);
    private string? userId;
    private string userName = "Viewer";
    private string newComment = "";

    protected override async Task OnParametersSetAsync()
    {
        allItems = await PortfolioService.LoadAsync();
        item = PortfolioService.GetById(Id);
        if (item != null)
        {
            previous = PortfolioService.GetPrevious(Id);
            next = PortfolioService.GetNext(Id);

            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            userName = authState.User.Identity?.Name?.Split('@')[0] ?? "Viewer";
            engagement = await Supabase.GetEngagementAsync(Id, userId);
        }
    }

    private async Task ToggleLike()
    {
        if (userId is null)
            return;

        await Supabase.ToggleLikeAsync(Id, userId, engagement.IsLiked);
        engagement = await Supabase.GetEngagementAsync(Id, userId);
    }

    private async Task AddComment()
    {
        if (userId is null || string.IsNullOrWhiteSpace(newComment))
            return;

        await Supabase.AddCommentAsync(Id, userId, userName, newComment);
        newComment = "";
        engagement = await Supabase.GetEngagementAsync(Id, userId);
    }

    private async Task ToggleFullscreen()
    {
        await JS.InvokeVoidAsync("ppToggleFullscreen", "pp-photo-view");
    }
}
