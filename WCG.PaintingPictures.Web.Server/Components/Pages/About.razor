@page "/about"
@rendermode InteractiveServer
@inject SiteIdentityService IdentityService

<PageTitle>About — @identity.SiteTitle</PageTitle>

<SiteHeader />

<main class="pp-simple-page">
    <h1 class="pp-simple-page__title">About</h1>
    <p class="pp-simple-page__lead">
        @identity.SiteTitle is the work of @identity.ArtistName.
    </p>
    <p class="pp-simple-page__body">
        @identity.Statement
    </p>
    <p class="pp-simple-page__body">
        Each piece is given room to be seen and read — photographs, drawings, and poems
        as one quiet practice of looking.
    </p>
</main>

<SiteFooter />

@code {
    private SiteIdentity identity = SiteIdentity.Defaults;

    protected override async Task OnInitializedAsync()
    {
        identity = await IdentityService.GetAsync();
    }
}
