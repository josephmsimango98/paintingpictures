@page "/admin/portfolio"
@attribute [Authorize(Roles = "admin")]
@rendermode InteractiveServer
@inject PortfolioService PortfolioService
@inject IJSRuntime JS

<PageTitle>Portfolio — Admin</PageTitle>

<SiteHeader />

<div class="pp-admin-page">
    <div class="pp-admin-header">
        <h2 class="pp-admin-title">Portfolio items</h2>
        <div class="pp-admin-header-actions">
            <button type="button" class="pp-btn pp-btn--accent" @onclick="NewItem" disabled="@isBusy">New item</button>
            <a href="@BackHref" class="pp-admin-back">← Back to site</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <p class="@(statusIsError ? "pp-admin-status pp-admin-status--error" : "pp-admin-status")">@statusMessage</p>
    }

    @if (Editing != null)
    {
        <div class="pp-admin-form-wrap">
            <h3 class="pp-admin-form-title">@(Editing.Id == 0 ? "New item" : "Edit item")</h3>
            <div class="pp-admin-form">
                <fieldset class="pp-admin-fieldset">
                    <legend class="pp-admin-fieldset__legend">General</legend>
                    <div class="pp-admin-field-row">
                        <div class="pp-admin-field">
                            <label class="pp-admin-label">Title</label>
                            <input class="pp-admin-input" @bind="Editing.Title" placeholder="Title" />
                        </div>
                        <div class="pp-admin-field">
                            <label class="pp-admin-label">Type</label>
                            <select class="pp-admin-input" @bind="Editing.Type">
                                <option value="photograph">Photograph</option>
                                <option value="drawing">Drawing</option>
                                <option value="poem">Poem</option>
                            </select>
                        </div>
                    </div>
                    <div class="pp-admin-field">
                        <label class="pp-admin-label">Description</label>
                        <textarea class="pp-admin-input pp-admin-textarea" @bind="Editing.Description" placeholder="Short description"></textarea>
                    </div>
                </fieldset>

                <fieldset class="pp-admin-fieldset">
                    <legend class="pp-admin-fieldset__legend">Media</legend>
                    <div class="pp-admin-field">
                        <label class="pp-admin-label">Upload picture</label>
                        <div class="pp-admin-upload">
                            <input type="file"
                                   @ref="fileInput"
                                   @onchange="OnImageSelected"
                                   accept=".jpg,.jpeg,.png,.webp,.gif,.heic,.heif,image/jpeg,image/png,image/webp,image/gif,image/heic,image/heif" />
                            @if (isUploading)
                            {
                                <span class="pp-admin-upload-status">Uploading…</span>
                            }
                        </div>
                    </div>
                    <div class="pp-admin-field">
                        <label class="pp-admin-label">Image URL (original)</label>
                        <input class="pp-admin-input" @bind="Editing.Image" placeholder="https://… or upload above" />
                    </div>
                    @if (!string.IsNullOrEmpty(previewSrc))
                    {
                        <div class="pp-admin-field">
                            <label class="pp-admin-label">Preview</label>
                            <div class="pp-admin-preview">
                                <img src="@previewSrc" alt="Preview" />
                            </div>
                        </div>
                    }
                    <div class="pp-admin-field-row">
                        <div class="pp-admin-field">
                            <label class="pp-admin-label">Width <span>(from EXIF / file)</span></label>
                            <input class="pp-admin-input" type="number" min="1" @bind="Editing.ImageWidth" placeholder="from file metadata" />
                        </div>
                        <div class="pp-admin-field">
                            <label class="pp-admin-label">Height <span>(from EXIF / file)</span></label>
                            <input class="pp-admin-input" type="number" min="1" @bind="Editing.ImageHeight" placeholder="from file metadata" />
                        </div>
                    </div>
                    <div class="pp-admin-field-row">
                        <div class="pp-admin-field">
                            <label class="pp-admin-label">Latitude</label>
                            <input class="pp-admin-input" type="number" step="any" @bind="Editing.Latitude" placeholder="from EXIF" />
                        </div>
                        <div class="pp-admin-field">
                            <label class="pp-admin-label">Longitude</label>
                            <input class="pp-admin-input" type="number" step="any" @bind="Editing.Longitude" placeholder="from EXIF" />
                        </div>
                    </div>
                    <div class="pp-admin-field-row">
                        <div class="pp-admin-field">
                            <label class="pp-admin-label">Taken at</label>
                            <input class="pp-admin-input" @bind="takenAtLocal" placeholder="from EXIF" />
                        </div>
                        <div class="pp-admin-field">
                            <label class="pp-admin-label">Camera</label>
                            <input class="pp-admin-input"
                                   value="@CameraLabel"
                                   @onchange="OnCameraChanged"
                                   placeholder="Make / model from EXIF" />
                        </div>
                    </div>
                </fieldset>

                <fieldset class="pp-admin-fieldset">
                    <legend class="pp-admin-fieldset__legend">Writing</legend>
                    <div class="pp-admin-field">
                        <label class="pp-admin-label">Poem</label>
                        <textarea class="pp-admin-input pp-admin-textarea" @bind="Editing.Poem" placeholder="Poem text"></textarea>
                    </div>
                    <div class="pp-admin-field">
                        <label class="pp-admin-label">Thoughts</label>
                        <textarea class="pp-admin-input pp-admin-textarea" @bind="Editing.Thoughts" placeholder="Notes and thoughts"></textarea>
                    </div>
                </fieldset>

                <fieldset class="pp-admin-fieldset">
                    <legend class="pp-admin-fieldset__legend">Visibility</legend>
                    <label class="pp-admin-check">
                        <input type="checkbox" @bind="Editing.IsPublished" />
                        <span>
                            <strong>Published</strong>
                            <small>Visible on the public site when checked. Uncheck to keep as a draft.</small>
                        </span>
                    </label>
                </fieldset>

                <div class="pp-admin-form-actions">
                    <button type="button" class="pp-btn pp-btn--accent" @onclick="SaveItem" disabled="@(isBusy || isUploading)">Save</button>
                    @if (Editing.Id != 0)
                    {
                        <button type="button"
                                class="pp-btn pp-btn--danger"
                                @onclick="() => DeleteItem(Editing.Id)"
                                disabled="@isBusy">
                            Delete
                        </button>
                    }
                    <button type="button" class="pp-btn" @onclick="CancelEdit" disabled="@isBusy">Cancel</button>
                </div>
            </div>
        </div>
    }

    <div class="pp-admin-table-wrap">
        @if (isLoading)
        {
            <p class="pp-admin-placeholder-body">Loading portfolio…</p>
        }
        else if (items.Count == 0)
        {
            <div class="pp-admin-placeholder">
                <p class="pp-admin-placeholder-title">No portfolio items yet</p>
                <p class="pp-admin-placeholder-body">Create a new item and upload a picture to get started.</p>
            </div>
        }
        else
        {
            <div class="pp-admin-list-toolbar">
                <nav class="pp-admin-list-filters" aria-label="Category">
                    <button type="button"
                            class="pp-admin-list-filter @(filterType == "all" ? "is-active" : null)"
                            @onclick='() => SetTypeFilter("all")'>All</button>
                    <button type="button"
                            class="pp-admin-list-filter @(filterType == PortfolioMedia.Photograph ? "is-active" : null)"
                            @onclick='() => SetTypeFilter(PortfolioMedia.Photograph)'>Photographs</button>
                    <button type="button"
                            class="pp-admin-list-filter @(filterType == PortfolioMedia.Drawing ? "is-active" : null)"
                            @onclick='() => SetTypeFilter(PortfolioMedia.Drawing)'>Drawings</button>
                    <button type="button"
                            class="pp-admin-list-filter @(filterType == PortfolioMedia.Poem ? "is-active" : null)"
                            @onclick='() => SetTypeFilter(PortfolioMedia.Poem)'>Poems</button>
                </nav>
                <div class="pp-admin-list-toolbar__right">
                    <select class="pp-admin-input pp-admin-list-visibility"
                            value="@filterVisibility"
                            @onchange="OnVisibilityFilterChanged"
                            aria-label="Visibility">
                        <option value="all">All visibility</option>
                        <option value="published">Published</option>
                        <option value="draft">Drafts</option>
                    </select>
                    <input class="pp-admin-input pp-admin-list-search"
                           @bind="searchText"
                           @bind:event="oninput"
                           placeholder="Search title…"
                           aria-label="Search by title" />
                    <span class="pp-admin-list-count">@FilteredItems.Count of @items.Count</span>
                </div>
            </div>

            @if (FilteredItems.Count == 0)
            {
                <div class="pp-admin-placeholder">
                    <p class="pp-admin-placeholder-title">No matching items</p>
                    <p class="pp-admin-placeholder-body">Try All, clear the search, or change visibility.</p>
                </div>
            }
            else
            {
                <table class="pp-admin-table">
                    <thead>
                        <tr>
                            <th>Preview</th>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Visibility</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in FilteredItems)
                        {
                            var captured = item;
                            <tr>
                                <td class="pp-admin-td-thumb">
                                    @if (captured.HasImage)
                                    {
                                        <img src="@captured.DisplayImageUrl"
                                             alt=""
                                             class="pp-admin-thumb"
                                             loading="lazy"
                                             onerror="this.onerror=null;this.replaceWith(Object.assign(document.createElement('span'),{className:'pp-admin-thumb pp-admin-thumb--empty',textContent:'—'}));" />
                                    }
                                    else
                                    {
                                        <span class="pp-admin-thumb pp-admin-thumb--empty">—</span>
                                    }
                                </td>
                                <td class="pp-admin-td-title">@captured.Title</td>
                                <td><span class="pp-type-badge">@captured.TypeLabel</span></td>
                                <td>
                                    <span class="pp-visibility-badge @(captured.IsPublished ? "is-published" : "is-draft")">
                                        @captured.VisibilityLabel
                                    </span>
                                </td>
                                <td class="pp-admin-td-actions">
                                    <button type="button" class="pp-btn pp-btn--sm" @onclick="() => EditItem(captured)">Edit</button>
                                    <button type="button"
                                            class="pp-btn pp-btn--sm"
                                            @onclick="() => TogglePublished(captured)"
                                            disabled="@isBusy">
                                        @(captured.IsPublished ? "Unpublish" : "Publish")
                                    </button>
                                    <button type="button"
                                            class="pp-btn pp-btn--sm pp-btn--danger"
                                            @onclick="() => DeleteItem(captured.Id)"
                                            disabled="@isBusy">
                                        Delete
                                    </button>
                                    <a href="/item/@captured.Id" class="pp-admin-view-link">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "itemId")]
    public int? ItemId { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "create")]
    public bool Create { get; set; }

    [SupplyParameterFromQuery(Name = "type")]
    public string? Type { get; set; }

    private IReadOnlyList<PortfolioItem> items = [];
    private PortfolioItem? Editing;
    private string? editingPreviewDataUrl;
    private ElementReference fileInput;
    private bool isLoading = true;
    private bool isBusy;
    private bool isUploading;
    private string? statusMessage;
    private bool statusIsError;
    private string filterType = "all";
    private string filterVisibility = "all";
    private string searchText = "";
    private string BackHref => LocalReturnUrl(ReturnUrl);

    private IReadOnlyList<PortfolioItem> FilteredItems
    {
        get
        {
            IEnumerable<PortfolioItem> query = items;

            if (filterType is not "all")
            {
                query = query.Where(x =>
                    string.Equals(x.Type, filterType, StringComparison.OrdinalIgnoreCase));
            }

            query = filterVisibility switch
            {
                "published" => query.Where(x => x.IsPublished),
                "draft" => query.Where(x => !x.IsPublished),
                _ => query
            };

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                var term = searchText.Trim();
                query = query.Where(x =>
                    x.Title.Contains(term, StringComparison.OrdinalIgnoreCase));
            }

            return query.ToList();
        }
    }

    private string? previewSrc =>
        editingPreviewDataUrl
        ?? Editing?.DisplayImageUrl
        ?? Editing?.Image;

    private string CameraLabel =>
        string.Join(" ", new[] { Editing?.CameraMake, Editing?.CameraModel }
            .Where(x => !string.IsNullOrWhiteSpace(x)));

    private string takenAtLocal
    {
        get => Editing?.TakenAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "";
        set
        {
            if (Editing is null)
                return;
            if (string.IsNullOrWhiteSpace(value))
            {
                Editing.TakenAt = null;
                return;
            }

            if (DateTime.TryParse(value, out var parsed))
                Editing.TakenAt = new DateTimeOffset(parsed);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            items = await PortfolioService.LoadAsync() ?? [];
        }
        catch (Exception ex)
        {
            items = [];
            SetStatus($"Could not load portfolio: {ex.Message}", isError: true);
        }
        finally
        {
            isLoading = false;
        }

        if (ItemId is int itemId)
        {
            var selected = items.FirstOrDefault(x => x.Id == itemId);
            if (selected is not null)
                EditItem(selected);
        }
        else if (Create)
        {
            StartNewItem(Type);
            if (!string.IsNullOrWhiteSpace(Type))
                filterType = PortfolioMedia.Normalize(Type);
        }
    }

    private void SetTypeFilter(string type)
    {
        filterType = type;
    }

    private void OnVisibilityFilterChanged(ChangeEventArgs args)
    {
        filterVisibility = args.Value?.ToString() ?? "all";
    }

    private static string LocalReturnUrl(string? value) =>
        !string.IsNullOrWhiteSpace(value)
        && value.StartsWith('/')
        && !value.StartsWith("//")
        && !value.StartsWith("/\\")
            ? value
            : "/";

    private void NewItem()
    {
        StartNewItem(null);
    }

    private void StartNewItem(string? type)
    {
        statusMessage = null;
        Editing = new PortfolioItem
        {
            Type = PortfolioMedia.Normalize(type),
            IsPublished = false
        };
        editingPreviewDataUrl = null;
    }

    private void EditItem(PortfolioItem item)
    {
        statusMessage = null;
        editingPreviewDataUrl = null;
        Editing = CloneItem(item);
    }

    private void OnCameraChanged(ChangeEventArgs args)
    {
        if (Editing is null)
            return;

        var raw = args.Value?.ToString()?.Trim() ?? "";
        if (string.IsNullOrWhiteSpace(raw))
        {
            Editing.CameraMake = null;
            Editing.CameraModel = null;
            return;
        }

        var parts = raw.Split(' ', 2, StringSplitOptions.RemoveEmptyEntries);
        Editing.CameraMake = parts.ElementAtOrDefault(0);
        Editing.CameraModel = parts.Length > 1 ? parts[1] : null;
    }

    private void CancelEdit()
    {
        Editing = null;
        editingPreviewDataUrl = null;
        isUploading = false;
    }

    private async Task OnImageSelected(ChangeEventArgs _)
    {
        if (Editing is null)
            return;

        isUploading = true;
        statusMessage = null;
        try
        {
            var uploaded = await JS.InvokeAsync<BrowserUploadResult>(
                "ppUploadPortfolioImage",
                fileInput,
                "/api/admin/portfolio/upload");

            if (string.IsNullOrWhiteSpace(uploaded.Url))
                throw new InvalidOperationException("Upload returned no image URL.");

            Editing.Image = uploaded.Url;
            Editing.ImageDisplay = uploaded.DisplayUrl;
            if (uploaded.Width > 0 && uploaded.Height > 0)
            {
                Editing.ImageWidth = uploaded.Width;
                Editing.ImageHeight = uploaded.Height;
            }
            Editing.Latitude = uploaded.Latitude;
            Editing.Longitude = uploaded.Longitude;
            Editing.TakenAt = uploaded.TakenAt;
            Editing.CameraMake = uploaded.CameraMake;
            Editing.CameraModel = uploaded.CameraModel;
            editingPreviewDataUrl = uploaded.PreviewDataUrl ?? uploaded.DisplayUrl;

            var metaBits = new List<string>();
            if (uploaded.Width > 0 && uploaded.Height > 0)
                metaBits.Add($"{uploaded.Width} × {uploaded.Height}");
            if (uploaded.IsHeic)
                metaBits.Add("original HEIC kept");
            if (!string.IsNullOrWhiteSpace(uploaded.DisplayUrl))
                metaBits.Add("JPEG preview ready");
            if (uploaded.Latitude is not null && uploaded.Longitude is not null)
                metaBits.Add($"location {uploaded.Latitude}, {uploaded.Longitude}");
            if (uploaded.TakenAt is not null)
                metaBits.Add($"taken {uploaded.TakenAt.Value.LocalDateTime:g}");
            if (!string.IsNullOrWhiteSpace(uploaded.CameraMake) || !string.IsNullOrWhiteSpace(uploaded.CameraModel))
                metaBits.Add($"{uploaded.CameraMake} {uploaded.CameraModel}".Trim());
            if (!string.IsNullOrWhiteSpace(uploaded.InspectError))
                metaBits.Add($"metadata warning: {uploaded.InspectError}");
            if (!string.IsNullOrWhiteSpace(uploaded.ConvertError))
                metaBits.Add($"convert warning: {uploaded.ConvertError}");

            var metaNote = metaBits.Count == 0 ? "" : " " + string.Join(" · ", metaBits) + ".";
            SetStatus(
                $"Picture uploaded.{metaNote} Save the item to keep the change.",
                isError: !string.IsNullOrWhiteSpace(uploaded.InspectError) && uploaded.Width <= 0);
        }
        catch (Exception ex)
        {
            var detail = ex.InnerException?.Message ?? ex.Message;
            SetStatus($"Upload failed: {detail}", isError: true);
        }
        finally
        {
            isUploading = false;
        }
    }

    private async Task SaveItem()
    {
        if (Editing is null)
            return;

        if (isUploading)
        {
            SetStatus("Wait for the picture upload to finish before saving.", isError: true);
            return;
        }

        if (string.IsNullOrWhiteSpace(Editing.Title))
        {
            SetStatus("Title is required.", isError: true);
            return;
        }

        if ((Editing.Type is "photograph" or "drawing") && string.IsNullOrWhiteSpace(Editing.Image))
        {
            SetStatus(
                "Upload a picture before saving a photograph or drawing. Choose a file and wait until you see “Picture uploaded”.",
                isError: true);
            return;
        }

        isBusy = true;
        try
        {
            var wasPublished = Editing.IsPublished;
            if (Editing.Id == 0)
                await PortfolioService.AddAsync(Editing);
            else
                await PortfolioService.UpdateAsync(Editing);

            Editing = null;
            editingPreviewDataUrl = null;
            items = await PortfolioService.LoadAsync() ?? [];
            SetStatus(
                wasPublished
                    ? "Item saved and published."
                    : "Item saved as draft.",
                isError: false);
        }
        catch (Exception ex)
        {
            SetStatus($"Save failed: {ex.Message}", isError: true);
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task TogglePublished(PortfolioItem item)
    {
        isBusy = true;
        try
        {
            var updated = CloneItem(item);
            updated.IsPublished = !item.IsPublished;
            await PortfolioService.UpdateAsync(updated);
            items = await PortfolioService.LoadAsync() ?? [];
            SetStatus(
                updated.IsPublished ? "Item published." : "Item unpublished (draft).",
                isError: false);
        }
        catch (Exception ex)
        {
            SetStatus($"Visibility update failed: {ex.Message}", isError: true);
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task DeleteItem(int id)
    {
        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            "Delete this work permanently? This cannot be undone.");
        if (!confirmed)
            return;

        isBusy = true;
        try
        {
            await PortfolioService.DeleteAsync(id);
            if (Editing?.Id == id)
            {
                Editing = null;
                editingPreviewDataUrl = null;
            }
            items = await PortfolioService.LoadAsync() ?? [];
            SetStatus("Item deleted.", isError: false);
        }
        catch (Exception ex)
        {
            SetStatus($"Delete failed: {ex.Message}", isError: true);
        }
        finally
        {
            isBusy = false;
        }
    }

    private void SetStatus(string message, bool isError)
    {
        statusMessage = message;
        statusIsError = isError;
    }

    private static PortfolioItem CloneItem(PortfolioItem item) => new()
    {
        Id = item.Id,
        Title = item.Title,
        Type = item.Type,
        Image = item.Image,
        ImageDisplay = item.ImageDisplay,
        Description = item.Description,
        Poem = item.Poem,
        Thoughts = item.Thoughts,
        ImageWidth = item.ImageWidth,
        ImageHeight = item.ImageHeight,
        Latitude = item.Latitude,
        Longitude = item.Longitude,
        TakenAt = item.TakenAt,
        CameraMake = item.CameraMake,
        CameraModel = item.CameraModel,
        IsPublished = item.IsPublished
    };

    private sealed class BrowserUploadResult
    {
        [System.Text.Json.Serialization.JsonPropertyName("url")]
        public string Url { get; set; } = "";

        [System.Text.Json.Serialization.JsonPropertyName("displayUrl")]
        public string? DisplayUrl { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("previewDataUrl")]
        public string? PreviewDataUrl { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("width")]
        public int Width { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("height")]
        public int Height { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("isHeic")]
        public bool IsHeic { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("latitude")]
        public double? Latitude { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("longitude")]
        public double? Longitude { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("takenAt")]
        public DateTimeOffset? TakenAt { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("cameraMake")]
        public string? CameraMake { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("cameraModel")]
        public string? CameraModel { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("inspectError")]
        public string? InspectError { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("convertError")]
        public string? ConvertError { get; set; }
    }
}
