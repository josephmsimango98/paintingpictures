<AuthorizeView Roles="admin">
    <Authorized>
        <a href="@Href" class="pp-studio-edit-link">
            @if (AddIcon)
            {
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M8 2.5v11M2.5 8h11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                </svg>
            }
            else
            {
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="m10.9 2.1 3 3-8.2 8.2-3.8.8.8-3.8 8.2-8.2Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round" />
                    <path d="m9.8 3.2 3 3" stroke="currentColor" stroke-width="1.25" />
                </svg>
            }
            @Label
        </a>
    </Authorized>
</AuthorizeView>

@code {
    [Parameter, EditorRequired]
    public string Href { get; set; } = "";

    [Parameter]
    public string Label { get; set; } = "Edit";

    [Parameter]
    public bool AddIcon { get; set; }
}
