@inject IJSRuntime JS

<header class="pp-site-header">
    <div class="pp-site-header__inner">
        <div class="pp-site-header__left">
            <button type="button"
                    class="pp-icon-btn pp-site-header__menu"
                    aria-label="Open menu"
                    aria-expanded="@menuOpen"
                    @onclick="ToggleMenu">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M3 5.5h14M3 10h14M3 14.5h14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
            </button>
        </div>

        <a href="/" class="pp-site-brand">
            <span class="pp-site-brand__mark">
                <img src="images/mimic-logo.png" alt="" class="pp-site-brand__logo" />
                <span class="pp-site-brand__title">The Irony</span>
            </span>
            <span class="pp-site-brand__tagline">Selected works · Studies · Fragments</span>
        </a>

        <div class="pp-site-header__right">
            <nav class="pp-site-nav" aria-label="Primary">
                <a href="/works" class="pp-site-nav__link">Collections</a>
                <a href="/about" class="pp-site-nav__link">About</a>
                <a href="/contact" class="pp-site-nav__link">Contact</a>
            </nav>

            <div class="pp-site-header__actions">
                <button type="button"
                        class="pp-icon-btn pp-site-header__theme"
                        title="@(IsLight ? "Switch to dark" : "Switch to light")"
                        aria-label="Toggle theme"
                        @onclick="ToggleTheme">
                    @if (IsLight)
                    {
                        <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                            <path d="M8.003 1C11.868 1.001 15.002 4.134 15.002 8c0 3.866-3.134 7-7 7a7.01 7.01 0 0 1-6.464-4.309.75.75 0 0 1 .474-.857A6.004 6.004 0 0 0 8.002 4a6 6 0 0 0-.46-2.308.75.75 0 0 1 .461-.692Z"/>
                        </svg>
                    }
                    else
                    {
                        <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                            <path d="M8 1.5a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-1 0V2a.5.5 0 0 1 .5-.5Zm0 11a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-1 0v-1a.5.5 0 0 1 .5-.5ZM2 7.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5Zm10.5 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5ZM8 5a3 3 0 1 1 0 6 3 3 0 0 1 0-6Z"/>
                        </svg>
                    }
                </button>

                <AuthorizeView>
                    <Authorized>
                        <a href="/api/auth/logout" class="pp-site-auth-link" title="@context.User.Identity?.Name">
                            @(context.User.Identity?.Name?.Split('@')[0] ?? "Account")
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="pp-site-auth-link">Sign in</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </div>

    @if (menuOpen)
    {
        <div class="pp-drawer-backdrop" @onclick="CloseMenu"></div>
        <aside class="pp-drawer" role="dialog" aria-label="Site menu">
            <div class="pp-drawer__head">
                <span class="pp-drawer__label">Navigate</span>
                <button type="button" class="pp-icon-btn" aria-label="Close menu" @onclick="CloseMenu">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                        <path d="M4 4l10 10M14 4 4 14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                    </svg>
                </button>
            </div>
            <nav class="pp-drawer__nav">
                <a href="/" @onclick="CloseMenu">Home</a>
                <a href="/works" @onclick="CloseMenu">Collections</a>
                <a href="/works?type=photograph" @onclick="CloseMenu">Studies</a>
                <a href="/works?type=drawing" @onclick="CloseMenu">Observations</a>
                <a href="/works?type=poem" @onclick="CloseMenu">Fragments</a>
                <a href="/about" @onclick="CloseMenu">About</a>
                <a href="/contact" @onclick="CloseMenu">Contact</a>
                <AuthorizeView Roles="admin">
                    <Authorized>
                        <a href="/admin" class="pp-drawer__studio" @onclick="CloseMenu">Go to studio</a>
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView>
                    <Authorized>
                        <a href="/api/auth/logout">Sign out</a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" @onclick="CloseMenu">Sign in</a>
                    </NotAuthorized>
                </AuthorizeView>
            </nav>
        </aside>
    }
</header>

@code {
    private bool IsLight;
    private bool menuOpen;

    private void ToggleMenu() => menuOpen = !menuOpen;
    private void CloseMenu() => menuOpen = false;

    private async Task ToggleTheme()
    {
        IsLight = !IsLight;
        await JS.InvokeVoidAsync("ppSetTheme", IsLight);
    }
}
