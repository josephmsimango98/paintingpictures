@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IDisposable

<header class="pp-site-header">
    <div class="pp-site-header__inner">
        <div class="pp-site-header__left">
            <button type="button"
                    class="pp-icon-btn pp-site-header__menu"
                    aria-label="Open menu"
                    aria-expanded="@menuOpen"
                    @onclick="ToggleMenu">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M3 5.5h14M3 10h14M3 14.5h14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
            </button>

            <div class="pp-site-brand">
                <a href="/" class="pp-site-brand__mark" aria-label="The Irony home">
                    <img src="images/mimic-logo.png" alt="" class="pp-site-brand__logo" />
                </a>
                <div class="pp-site-brand__copy">
                    <a href="/" class="pp-site-brand__title">The Irony</a>
                    <nav class="pp-site-brand__tagline" aria-label="Categories">
                        <a href="/works?type=photograph&collection=all"
                           class="pp-site-brand__medium @(IsMediumActive("photograph") ? "is-active" : null)">
                            Photographs
                        </a>
                        <span class="pp-site-brand__sep" aria-hidden="true">·</span>
                        <a href="/works?type=drawing&collection=all"
                           class="pp-site-brand__medium @(IsMediumActive("drawing") ? "is-active" : null)">
                            Drawings
                        </a>
                        <span class="pp-site-brand__sep" aria-hidden="true">·</span>
                        <a href="/works?type=poem&collection=all"
                           class="pp-site-brand__medium @(IsMediumActive("poem") ? "is-active" : null)">
                            Poems
                        </a>
                    </nav>
                </div>
            </div>
        </div>

        <div class="pp-site-header__right">
            <button type="button"
                    class="pp-icon-btn pp-site-header__theme"
                    title="@(IsLight ? "Switch to dark" : "Switch to light")"
                    aria-label="Toggle theme"
                    @onclick="ToggleTheme">
                @if (IsLight)
                {
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <circle cx="8" cy="8" r="3.25" stroke="currentColor" stroke-width="1.3"/>
                        <path d="M8 1.25v1.5M8 13.25v1.5M1.25 8h1.5M13.25 8h1.5M3.05 3.05l1.06 1.06M11.89 11.89l1.06 1.06M3.05 12.95l1.06-1.06M11.89 4.11l1.06-1.06" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                    </svg>
                }
                else
                {
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M13.2 9.35A5.75 5.75 0 0 1 6.65 2.8 5.75 5.75 0 1 0 13.2 9.35Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
                    </svg>
                }
            </button>

            <span class="pp-site-header__rule" aria-hidden="true"></span>

            <AuthorizeView>
                <Authorized>
                    <a href="/api/auth/logout" class="pp-site-account" title="@context.User.Identity?.Name">
                        <span class="pp-site-account__avatar" aria-hidden="true">
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                                <circle cx="8" cy="5.5" r="2.4" stroke="currentColor" stroke-width="1.3"/>
                                <path d="M3.2 13.2c.7-2.2 2.4-3.4 4.8-3.4s4.1 1.2 4.8 3.4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                            </svg>
                        </span>
                        <span class="pp-site-account__name">@(context.User.Identity?.Name?.Split('@')[0] ?? "Account")</span>
                        <svg class="pp-site-account__chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                            <path d="M2 3.5 5 6.5 8 3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </a>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="pp-site-account">
                        <span class="pp-site-account__avatar" aria-hidden="true">
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                                <circle cx="8" cy="5.5" r="2.4" stroke="currentColor" stroke-width="1.3"/>
                                <path d="M3.2 13.2c.7-2.2 2.4-3.4 4.8-3.4s4.1 1.2 4.8 3.4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                            </svg>
                        </span>
                        <span class="pp-site-account__name">Sign in</span>
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>

    @if (menuOpen)
    {
        <div class="pp-drawer-backdrop" @onclick="CloseMenu"></div>
        <aside class="pp-drawer" role="dialog" aria-label="Site menu">
            <div class="pp-drawer__head">
                <span class="pp-drawer__label">Navigate</span>
                <button type="button" class="pp-icon-btn" aria-label="Close menu" @onclick="CloseMenu">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                        <path d="M4 4l10 10M14 4 4 14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                    </svg>
                </button>
            </div>
            <nav class="pp-drawer__nav">
                <a href="/" @onclick="CloseMenu">Home</a>
                <AuthorizeView Roles="admin">
                    <Authorized>
                        <a href="/" class="pp-drawer__studio" @onclick="CloseMenu">Studio home</a>
                        <a href="/admin/identity" @onclick="CloseMenu">Site identity</a>
                        <a href="/admin/portfolio" @onclick="CloseMenu">Portfolio library</a>
                        <a href="/admin/users" @onclick="CloseMenu">Manage users</a>
                    </Authorized>
                </AuthorizeView>
                <a href="/works" @onclick="CloseMenu">Collections</a>
                <a href="/works?type=photograph" @onclick="CloseMenu">Photographs</a>
                <a href="/works?type=drawing" @onclick="CloseMenu">Drawings</a>
                <a href="/works?type=poem" @onclick="CloseMenu">Poems</a>
                <a href="/about" @onclick="CloseMenu">About</a>
                <a href="/contact" @onclick="CloseMenu">Contact</a>
                <AuthorizeView>
                    <Authorized>
                        <a href="/api/auth/logout">Sign out</a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" @onclick="CloseMenu">Sign in</a>
                    </NotAuthorized>
                </AuthorizeView>
            </nav>
        </aside>
    }
</header>

@code {
    private bool IsLight;
    private bool menuOpen;
    private bool themeReady;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || themeReady)
            return;

        try
        {
            IsLight = await JS.InvokeAsync<bool>("ppGetTheme");
            themeReady = true;
            StateHasChanged();
        }
        catch (JSException)
        {
            // Theme script may not be available during disconnect; keep current state.
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

    public void Dispose() =>
        Navigation.LocationChanged -= OnLocationChanged;

    private void ToggleMenu() => menuOpen = !menuOpen;
    private void CloseMenu() => menuOpen = false;

    private bool IsMediumActive(string medium)
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (!relative.StartsWith("works", StringComparison.OrdinalIgnoreCase))
            return false;

        var query = relative.Contains('?', StringComparison.Ordinal)
            ? relative[(relative.IndexOf('?') + 1)..]
            : "";
        var type = query
            .Split('&', StringSplitOptions.RemoveEmptyEntries)
            .Select(part => part.Split('=', 2))
            .Where(parts => parts.Length == 2 && parts[0].Equals("type", StringComparison.OrdinalIgnoreCase))
            .Select(parts => Uri.UnescapeDataString(parts[1]))
            .FirstOrDefault();

        return PortfolioMedia.Normalize(type).Equals(medium, StringComparison.OrdinalIgnoreCase);
    }

    private async Task ToggleTheme()
    {
        IsLight = !IsLight;
        await JS.InvokeVoidAsync("ppSetTheme", IsLight);
    }
}
