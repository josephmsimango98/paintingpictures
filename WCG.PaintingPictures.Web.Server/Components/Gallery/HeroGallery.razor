@inject HeroGalleryService HeroGalleryService

<section class="pp-hero-gallery pp-hero-gallery--@layoutKey" aria-label="Featured collections">
    <div class="pp-hero-gallery__grid">
        @foreach (var panel in panels)
        {
            <a href="@panel.Href"
               class="pp-hero-card @panel.ModifierClass @(panel.IsPoem ? "pp-hero-card--poem" : "")">
                @if (panel.IsPoem)
                {
                    <div class="pp-hero-card__poem">
                        <span class="pp-hero-card__quote-mark" aria-hidden="true">“</span>
                        <p class="pp-hero-card__quote">@panel.Quote</p>
                        <span class="pp-hero-card__poem-rule" aria-hidden="true"></span>
                        <span class="pp-hero-card__poem-label">Poem</span>
                    </div>
                }
                else
                {
                    <div class="pp-hero-card__media @(string.IsNullOrEmpty(panel.Image) ? "is-empty" : "")">
                        @if (!string.IsNullOrEmpty(panel.Image))
                        {
                            <img src="@panel.Image"
                                 alt=""
                                 class="pp-hero-card__img"
                                 loading="@(panel.IsFeatured ? "eager" : "lazy")" />
                        }
                        else
                        {
                            <div class="pp-hero-card__skeleton" aria-hidden="true"></div>
                        }
                    </div>
                    <div class="pp-hero-card__overlay">
                        @if (panel.IsFeatured)
                        {
                            <span class="pp-hero-card__eyebrow">Featured</span>
                        }
                        <h2 class="pp-hero-card__title">@panel.Title</h2>
                        <p class="pp-hero-card__desc">@panel.Description</p>
                        <span class="pp-hero-card__cta">
                            View Collection
                            <span class="pp-hero-card__cta-arrow" aria-hidden="true">→</span>
                        </span>
                    </div>
                }
            </a>
        }
    </div>
</section>

@code {
    private sealed record HeroPanel(
        string Title,
        string Description,
        string? Image,
        string Href,
        string ModifierClass,
        bool IsFeatured = false,
        bool IsPoem = false,
        string? Quote = null);

    private string layoutKey = HeroLayoutKeys.Editorial;
    private List<HeroPanel> panels = [];

    protected override async Task OnInitializedAsync()
    {
        var config = await HeroGalleryService.GetConfigAsync();
        layoutKey = HeroLayoutKeys.Normalize(config.LayoutKey);
        panels = config.Slots
            .OrderBy(x => x.SortOrder)
            .Select(ToPanel)
            .ToList();
    }

    private static HeroPanel ToPanel(HeroGallerySlotAssignment slot)
    {
        var item = slot.Item;
        var isFeatured = slot.SlotKey == HeroSlotKeys.Featured;
        var modifier = HeroSlotKeys.CssModifier(slot.SlotKey);

        if (item is null)
        {
            return new HeroPanel(
                Title: SlotFallbackTitle(slot.SlotKey),
                Description: "A work from the collection",
                Image: null,
                Href: FallbackHref(slot.SlotKey),
                ModifierClass: modifier,
                IsFeatured: isFeatured);
        }

        if (item.Type == "poem")
        {
            var poemLines = item.Poem?
                .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Take(3)
                .ToArray() ?? ["I am learning to sit with silence."];

            return new HeroPanel(
                Title: item.Title,
                Description: item.Description ?? "Words held in silence",
                Image: null,
                Href: $"/item/{item.Id}",
                ModifierClass: modifier,
                IsFeatured: isFeatured,
                IsPoem: true,
                Quote: string.Join("\n", poemLines));
        }

        return new HeroPanel(
            Title: TitleFor(item),
            Description: item.Description?.Split('.')[0] ?? "A study in light and presence",
            Image: item.Image,
            Href: $"/item/{item.Id}",
            ModifierClass: modifier,
            IsFeatured: isFeatured);
    }

    private static string TitleFor(PortfolioItem item) => item.Type switch
    {
        "drawing" => string.IsNullOrWhiteSpace(item.Title) ? "Drawings" : item.Title,
        "photograph" => string.IsNullOrWhiteSpace(item.Title) ? "Photography" : item.Title,
        _ => item.Title
    };

    private static string SlotFallbackTitle(string slotKey) => slotKey switch
    {
        HeroSlotKeys.Featured => "Featured",
        HeroSlotKeys.Secondary => "Collection",
        HeroSlotKeys.Tertiary => "Drawings",
        HeroSlotKeys.Quaternary => "Photography",
        _ => "Collection"
    };

    private static string FallbackHref(string slotKey) => slotKey switch
    {
        HeroSlotKeys.Tertiary => "/works?type=drawing",
        HeroSlotKeys.Quaternary => "/works?type=photograph",
        HeroSlotKeys.Secondary => "/works?type=poem",
        _ => "/works"
    };
}
