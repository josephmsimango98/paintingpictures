<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["WCG.PaintingPictures.Web.Server.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <script>
        (function () {
            var key = 'pp-theme';
            function systemIsLight() {
                return window.matchMedia('(prefers-color-scheme: light)').matches;
            }
            function resolve() {
                var stored = localStorage.getItem(key);
                if (stored === 'light') return true;
                if (stored === 'dark') return false;
                return systemIsLight();
            }
            function apply(light) {
                document.documentElement.classList.toggle('pp-light', !!light);
            }
            window.ppGetTheme = function () { return resolve(); };
            window.ppSetTheme = function (light) {
                localStorage.setItem(key, light ? 'light' : 'dark');
                apply(light);
                return !!light;
            };
            apply(resolve());
            window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function () {
                if (!localStorage.getItem(key))
                    apply(systemIsLight());
            });
        })();
    </script>
</head>

<body>
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <ReconnectModal />
    <script src="_content/Microsoft.FluentUI.AspNetCore.Components/Microsoft.FluentUI.AspNetCore.Components.lib.module.js" type="module" async></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        window.ppToggleFullscreen = function(elId) {
            var el = document.getElementById(elId);
            if (!el) return;
            if (!document.fullscreenElement) {
                el.requestFullscreen().catch(function() {});
            } else {
                document.exitFullscreen();
            }
        };

        window.ppUploadPortfolioImage = async function(input, url) {
            if (!input || !input.files || !input.files[0])
                throw new Error('No file selected.');
            var file = input.files[0];
            var form = new FormData();
            form.append('file', file);
            var res = await fetch(url, {
                method: 'POST',
                body: form,
                credentials: 'same-origin'
            });
            var text = await res.text();
            var payload = null;
            try { payload = text ? JSON.parse(text) : null; } catch (_) {}
            if (!res.ok) {
                var detail = (payload && (payload.detail || payload.title)) || text || ('Upload failed (' + res.status + ')');
                throw new Error(detail);
            }
            return payload;
        };
    </script>
</body>

</html>
